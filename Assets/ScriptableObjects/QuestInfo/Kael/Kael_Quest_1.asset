  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24a04ab43ec46244e881a610d2970b30, type: 3}
  m_Name: Kael_Quest_1
  m_EditorClassIdentifier: Assembly-CSharp::QuestInfo
  initialDialog:
  - Hold it right there, rookie. You're not thinking of heading past the gates with
    just your bare hands, are you?
  - The wilderness out there doesn't forgive. You need a proper weapon to defend
    yourself. A sturdy Iron Sword should do the trick.
  - If you don't want to risk mining Iron Ore in the dark caves just yet, remember
    that the local merchant usually sells Iron Ingots. Go craft one at the workbench
    and show it to me.
  initialDialogClips:
  - {fileID: 8300000, guid: 22e0134ff22a4794e80f63fd668228c3, type: 3}
  - {fileID: 8300000, guid: b41c68eb44d8bc648b244cda7e59384e, type: 3}
  - {fileID: 8300000, guid: e1a197f6a2840f34e80e1edcb4eb1682, type: 3}
  acceptOption: I'll craft that Iron Sword. I'll be right back.
  acceptAnswer: That's the spirit! You'll need 5 Iron Ingots and 3 Wooden Stick.
    Good luck.
  acceptAnswerClip: {fileID: 8300000, guid: 782c9b2c7c2af4c40866ba435a38c6e1, type: 3}
  declineOption: I don't need a sword right now. I'll take my chances.
  declineAnswer: Suit yourself. Don't come crying to me when a crawler takes a bite
    out of you.
  declineAnswerClip: {fileID: 8300000, guid: 6b715533f7d56b444a39187cc7061726, type: 3}
  comebackAfterDecline: Changed your mind about that Iron Sword? The wilderness hasn't
    gotten any safer since we last spoke.
  comebackAfterDeclineClip: {fileID: 8300000, guid: 4de8a8c4c5e7ee248bcc90667adc8aaf, type: 3}
  comebackInProgress: Where is the sword? Remember, you need 5 Iron Ingots and 3
    Wooden Stick. If you are struggling to find iron, go check the merchant's store!
  comebackInProgressClip: {fileID: 8300000, guid: b4f8ccf7bfcb05649a04b88d5dcb4728, type: 3}
  comebackCompleted: Now that is a fine piece of craftsmanship! It has a good weight
    to it. You might actually survive out there after all.
  comebackCompletedClip: {fileID: 8300000, guid: 04e20453cbab54d49ab8470d1ab297e8, type: 3}
  finalWords: Keep your blade sharp and your eyes open. Here is a little something
    to help you on your journey.
  finalWordsClip: {fileID: 8300000, guid: f447465201b1691469d9060fd7300e99, type: 3}
  coinReward: 50
  rewardItem1: 
  rewardItem2: Iron Sword
  firstRequirementItem: Iron Sword
  firstRequirementAmount: 1
