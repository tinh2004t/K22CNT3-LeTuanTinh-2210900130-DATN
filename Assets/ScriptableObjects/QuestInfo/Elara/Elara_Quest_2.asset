  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24a04ab43ec46244e881a610d2970b30, type: 3}
  m_Name: Elara_Quest_2
  m_EditorClassIdentifier: Assembly-CSharp::QuestInfo
  initialDialog:
  - The garden is thriving thanks to your help. However, we are facing a serious
    problem. A large bear has appeared near the lake, trampling our sprouts and threatening
    everyone.
  - We need more meat reserves, and I also need a bear heart to brew a special tonic.
    Could you help me hunt 5 rabbits and take down that bear?
  initialDialogClips:
  - {fileID: 8300000, guid: 36fd0b1a5badc5740991754dd63d1316, type: 3}
  - {fileID: 8300000, guid: 4a7681b179c97884dbfafd1f41dcdfc9, type: 3}
  acceptOption: Leave it to me, I'll deal with the bear and bring back the meat.
  acceptAnswer: Please be careful! Bears are incredibly strong and aggressive. Don't
    forget to bring your best weapons.
  acceptAnswerClip: {fileID: 8300000, guid: aa13f2bf2574c2040a13a99aa5b4c030, type: 3}
  declineOption: Facing a bear is too dangerous. I'm not ready for that yet.
  declineAnswer: I understand. Come back when you feel strong enough. This garden
    won't survive if that bear keeps roaming around.
  declineAnswerClip: {fileID: 8300000, guid: 7b02fcca5160da24ba08997ea71b9587, type: 3}
  comebackAfterDecline: That bear is still wreaking havoc. Have you changed your
    mind about helping us?
  comebackAfterDeclineClip: {fileID: 8300000, guid: b60f944f797979349b4829f656a2d985, type: 3}
  comebackInProgress: Haven't gathered the materials yet? I need 5 pieces of rabbit
    meat and 1 bear heart. Stay safe out there!
  comebackInProgressClip: {fileID: 8300000, guid: d06e3c146bb6a5f4a88c7fefbf7a12ca, type: 3}
  comebackCompleted: Unbelievable! You actually managed to take it down. This is
    the best news our camp has had all day.
  comebackCompletedClip: {fileID: 8300000, guid: f56de347d241eac49956843cb0c1e9f2, type: 3}
  finalWords: Thank you for your bravery. With this meat and the bear heart, we'll
    have a warmer and healthier winter.
  finalWordsClip: {fileID: 8300000, guid: fcc6b93be3a87c24d9c66bd84869c796, type: 3}
  coinReward: 200
  rewardItem1: Health Potion
  rewardItem2: 
  firstRequirementItem: Raw Meat
  firstRequirementAmount: 5
  secondRequirementItem: Brear Heart
  secondRequirementAmount: 2
  hasCheckPoints: 0
  checkpoints: []
  unlocksNPC: 1
  npcToUnlock: 4
