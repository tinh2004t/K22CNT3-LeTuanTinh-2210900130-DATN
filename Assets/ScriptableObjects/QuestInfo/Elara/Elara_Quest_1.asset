  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24a04ab43ec46244e881a610d2970b30, type: 3}
  m_Name: Elara_Quest_1
  m_EditorClassIdentifier: Assembly-CSharp::QuestInfo
  initialDialog:
  - Ah, you must be the traveler Eldric mentioned. I'm Elara, and I'm trying to establish
    a small sustainable garden here so we don't have to rely solely on hunting.
  - I've heard that wild crops are flourishing near the East Lake. Could you go there
    and gather some fresh produce for our first harvest? I specifically need Tomatoes
    and Pumpkins.
  initialDialogClips:
  - {fileID: 8300000, guid: 41179e5671287ec41931e35734502717, type: 3}
  - {fileID: 8300000, guid: 9ee2c2f32d7e85d4eae423d093c4c60f, type: 3}
  acceptOption: I'll head to the lake and find those crops for you.
  acceptAnswer: Thank you! Be careful, the area around the lake can be slippery,
    and wild animals often gather there to drink. Bring me 3 Tomatoes and 5 Pumpkins.
  acceptAnswerClip: {fileID: 8300000, guid: d315b1217da2c564fa6e21ca07a73672, type: 3}
  declineOption: I'm not interested in gardening right now.
  declineAnswer: That's a pity. Fresh vegetables are vital for a healthy diet in
    this wilderness. Come back if you change your mind.
  declineAnswerClip: {fileID: 8300000, guid: 21e42fa1284fc3b4d9a48067f2b91317, type: 3}
  comebackAfterDecline: The soil is ready for planting, but I'm still missing the
    crops. Will you help me get them from the lake now?
  comebackAfterDeclineClip: {fileID: 8300000, guid: d5bd6baa8483a0042b059ac7c5f51d7e, type: 3}
  comebackInProgress: You haven't found enough yet? Remember, the lake is to the
    East. I need 3 Tomatoes and 5 Pumpkins to get started.
  comebackInProgressClip: {fileID: 8300000, guid: d397262d67a8b4c49bef7a1c42bb9dc1, type: 3}
  comebackCompleted: Wonderful! These look so fresh and ripe. This is exactly what
    we need to start our garden.
  comebackCompletedClip: {fileID: 8300000, guid: 1b2d8de1f15302948a95af74b488cd73, type: 3}
  finalWords: You've been a huge help. With these, we won't have to worry about starving
    when the game is scarce. Here is a little something for your trouble.
  finalWordsClip: {fileID: 8300000, guid: 8b93223dd12b1e64f9bf2936b1ff3fb5, type: 3}
  coinReward: 80
  rewardItem1: Tomato Seed
  rewardItem2: Pumpkin Seed
  firstRequirementItem: Tomato
  firstRequirementAmount: 3
  secondRequirementItem: Pumpkin
  secondRequirementAmount: 5
  hasCheckPoints: 0
  checkpoints: []
  unlocksNPC: 0
  npcToUnlock: 0
