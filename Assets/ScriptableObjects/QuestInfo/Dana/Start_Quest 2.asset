  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24a04ab43ec46244e881a610d2970b30, type: 3}
  m_Name: Start_Quest 2
  m_EditorClassIdentifier: Assembly-CSharp::QuestInfo
  initialDialog:
  - The weather out here is unforgiving, and leaving our supplies on the bare ground
    is a terrible idea.
  - We need a secure place. Let's start with the basics before we worry about a full
    roof.
  - Craft a Stone Axe, chop down some trees to gather 30 Wood, and build a Wooden
    Chest to store your items safely.
  initialDialogClips:
  - {fileID: 8300000, guid: d7c665acbf3fb3d4685f59787961e65f, type: 3}
  - {fileID: 8300000, guid: 00c942a6c2e959742986d8e1e29686a2, type: 3}
  - {fileID: 8300000, guid: c971267591d8cac4b909f6feb87937df, type: 3}
  acceptOption: I will gather the materials and build the chest.
  acceptAnswer: Excellent. Keep your eyes peeled while you're out in the forest.
  acceptAnswerClip: {fileID: 8300000, guid: 87c3c55a6e8b8f04f9896044f2a95851, type: 3}
  declineOption: I have other things to deal with right now.
  declineAnswer: Don't take too long. Our supplies won't protect themselves from
    scavengers.
  declineAnswerClip: {fileID: 8300000, guid: ea000b2629d8e104db216d24868afb17, type: 3}
  comebackAfterDecline: Have you changed your mind? Ready to start woodworking?
  comebackAfterDeclineClip: {fileID: 8300000, guid: 5b74928bee9709d409115ca9a195ee3c, type: 3}
  comebackInProgress: Still working on it? Remember, you need to craft an axe, gather
    15 Log, and place a Wooden Chest.
  comebackInProgressClip: {fileID: 8300000, guid: 38ef40db76924b842b03a4411f912419, type: 3}
  comebackCompleted: Great job! That chest will keep our hard-earned resources safe.
  comebackCompletedClip: {fileID: 8300000, guid: 08ceb276d1e7ffa47bce6d3045b3de6d, type: 3}
  finalWords: Now that we have basic storage, we can start planning a real shelter.
    Here, take these supplies for your hard work.
  finalWordsClip: {fileID: 8300000, guid: abb5fb604fbe033449147ba50abc8632, type: 3}
  coinReward: 50
  rewardItem1: Bread
  rewardItem2: Bread
  firstRequirementItem: Log
  firstRequirementAmount: 15
  secondRequirementItem: Plank
  secondRequirementAmount: 3
  hasCheckPoints: 0
  checkpoints: []
